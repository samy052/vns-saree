PORT=5003
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@host:5432/database
DB_SCHEMA=vns_saree
DB_SSL=auto
DB_LOGGING=false

# Keep DB_SYNC=none for normal development and production startup.
# Use DB_SYNC=alter only for a planned schema update run.
DB_SYNC=none
ALLOW_PRODUCTION_DB_SYNC=false

# Frontend / CORS
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Auth
JWT_SECRET=change-me
REFRESH_TOKEN_SECRET=change-me
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

# Uploads
UPLOAD_STORAGE=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email
EMAIL_USER=
EMAIL_PASS=

# Shipping
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
